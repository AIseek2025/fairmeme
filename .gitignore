# ===================================================================
# FairMeme — top-level .gitignore
# ===================================================================

# OS / editor
.DS_Store
Thumbs.db
*.swp
*~
.idea/
.vscode/
*.iml

# Secrets — NEVER commit
.env
.env.*
!.env.example
*.pem
*.key
*.keystore

# ----- Node / TypeScript -----
node_modules/
.next/
dist/
out/
build/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/
.pnpm-store/

# ----- Go -----
# Binaries
bin/
*.exe
*.test
*.out
# coverage
cover.out
*.cover

# ----- Solidity / Foundry -----
**/forge-cache/
**/cache/
**/out/
**/broadcast/
.forge-snapshots/

# ----- Anchor / Rust / Cargo -----
target/
Cargo.lock
**/.anchor/

# ----- Local archives / backup -----
.archive-original/
*.tar.gz
*.zip

# ----- Project-specific generated artifacts -----
graphify-out/
apps/listener/solprice
