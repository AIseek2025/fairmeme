# FairMeme Airdrop Service — environment variables
# Copy to .env and fill in. Never commit real values.

# ---- 3rd party API keys ----
MORALIS_API_KEY=
CGK_API_KEY=
HELIUS_API_KEY=
TWEETSCOUT_API_KEY=

# ---- Database ----
DB_HOST=
DB_PORT=5432
DB_USER=
DB_PASS=
DB_NAME=
DB_SSLMODE=disable

# ---- Redis ----
REDIS_ADDR=
REDIS_PASS=
REDIS_DB=0
