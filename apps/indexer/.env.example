# FairMeme Indexer — environment variables
# Copy to .env and fill in. Never commit real values.

DB_HOST=
DB_PORT=5432
DB_USER=
DB_PASS=
DB_NAME=

# Redis (optional, used for cursor checkpoints)
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASS=
REDIS_DB=0

# Solana RPC (use your own provider; Helius/QuickNode/etc.)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
FAIRMEME_PROGRAM_ID=HN6v9ASvYLuFbvW6b9tBCKoX6PH546MPKb4R4MSot8c8
FAIRMEME_REFERRAL_PROGRAM_ID=B5LrGrvdsdsmjYQPrg24kneF8DpztYm2RScq1DsbE92B

# Set true only when debugging; otherwise event payloads and DB topology stay quiet.
INDEXER_DEBUG=false
