# ============================================================
# FairMeme Web — Environment Variables
# Copy this file to .env (and .env.test / .env.production as needed) and fill in values.
# NEVER commit .env files containing real secrets.
# ============================================================

# ---- next-auth (Twitter login) ----
TWITTER_ID=
TWITTER_SECRET=
# Generate with: openssl rand -hex 32
AUTH_SECRET=

# ---- Pinata (IPFS) ----
PINATA_JWT=
PINATA_JWT_FOR_PROD=
NEXT_PUBLIC_GATEWAY_URL=gateway.pinata.cloud

# ---- Optional public runtime config ----
# NEXT_PUBLIC_ENV=test
NEXT_PUBLIC_WS_URL=wss://api.fairmeme.io/v1/ws
NEXT_PUBLIC_API_V1_BASE_URL=https://api.fairmeme.io/api/v1
NEXT_PUBLIC_API_V2_BASE_URL=https://airdrop.fairmeme.io
